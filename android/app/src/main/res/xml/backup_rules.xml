<?xml version="1.0" encoding="utf-8"?>
<!-- Android 11 and below (Auto Backup). Include-only: with an <include>
     present, ONLY listed paths are backed up — the multi-MB channel database
     is therefore implicitly excluded (it would blow the 25MB quota and is
     rebuilt from the provider on first sync anyway). -->
<full-backup-content>
    <include domain="file" path="app_flutter/lumen_vault.json"/>
</full-backup-content>

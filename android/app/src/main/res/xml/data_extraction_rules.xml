<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+. Same policy: back up only the credential vault (encrypted
     by Android with the device lock on-device and in transit). -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="app_flutter/lumen_vault.json"/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="app_flutter/lumen_vault.json"/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
